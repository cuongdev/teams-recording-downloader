{
   "action": {
      "default_icon": {
         "128": "icons/team_lit.png"
      }
   },
   "background": { "service_worker": "background.js" },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "intercept.js" ],
      "matches": [ "https://*.sharepoint.com/*", "https://teams.microsoft.com/*", "https://teams.cloud.microsoft/*" ],
      "run_at": "document_start",
      "world": "MAIN"
   }, {
      "all_frames": true,
      "js": [ "content.js" ],
      "matches": [ "https://*.sharepoint.com/*", "https://teams.microsoft.com/*", "https://teams.cloud.microsoft/*" ],
      "run_at": "document_idle"
   } ],
   "description": "Download Microsoft Teams / SharePoint Stream meeting recordings and transcripts (VTT), plus a local meeting-insights dashboard — all in-browser.",
   "host_permissions": [ "https://*.sharepoint.com/*", "https://*.svc.ms/*", "https://teams.microsoft.com/*", "https://teams.cloud.microsoft/*" ],
   "icons": {
      "128": "icons/team_unlit.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Teams Recording Downloader",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "2.10",
   "permissions": [ "storage" ],
   "optional_host_permissions": [ "https://*/*" ],
   "options_ui": { "page": "options.html", "open_in_tab": true },
   "web_accessible_resources": [ {
      "matches": [ "https://*.sharepoint.com/*", "https://teams.microsoft.com/*", "https://teams.cloud.microsoft/*" ],
      "resources": [ "mux-worker.js" ]
   } ]
}
